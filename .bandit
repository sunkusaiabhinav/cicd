# =============================================================
# FILE: .bandit
# PURPOSE: Configuration for Bandit — the Python security scanner.
#
# WHAT IS BANDIT?
#   Bandit scans your Python source code for common security issues
#   such as hardcoded passwords, use of weak cryptography, SQL injection
#   risks, and other OWASP-style vulnerabilities.
#
# HOW TO RUN:
#   bandit -r app/ -c .bandit
#
# CONFIG FORMAT:
#   This file must be valid YAML. Bandit reads it as a YAML config file.
#     - exclude_dirs: skip directories that don't need scanning
#     - skips: suppress specific Bandit check IDs
# =============================================================

# Directories to exclude from scanning
# Tests use assert statements which Bandit warns about (B101) — safe to skip
exclude_dirs:
  - tests
  - .venv
  - dist
  - build

# Skip specific check IDs:
#   B101 = assert_used — assert is fine in tests (already excluded above)
skips:
  - B101
